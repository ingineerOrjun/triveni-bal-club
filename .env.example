# Triveni Child Club Portal — environment template
# Copy to .env.local and fill in from your Supabase project (Settings → API).

# ── Supabase (required) ─────────────────────────────────────────────────────
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_, never commit a real value.
# Used for trusted admin operations and the bootstrap script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin (used for password-reset redirect URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Bootstrap (local development only) ──────────────────────────────────────
# Used by `npm run bootstrap` to create the first admin account.
# NOTE: quote any value containing '#' — dotenv treats an unquoted # as a comment.
BOOTSTRAP_ADMIN_EMAIL=admin@triveni.local
BOOTSTRAP_ADMIN_PASSWORD="Admin#12345"
BOOTSTRAP_ADMIN_NAME="Club Admin"

# Shared password for the demo moderator/member accounts (local dev only).
BOOTSTRAP_DEMO_PASSWORD="Demo#12345"
